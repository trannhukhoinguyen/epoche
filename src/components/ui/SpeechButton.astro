---
// src/components/SpeechButton.astro
---

<div class="flex items-center gap-4 select-none">
  <!-- Nút Điều Khiển Phát/Dừng -->
  <button id="tts-button" class="flex items-center gap-2 px-4 py-2 bg-zinc-100 hover:bg-zinc-200 dark:bg-zinc-800 dark:hover:bg-zinc-700 rounded-lg transition-all text-sm font-medium">
    <span id="tts-icon">🔊</span>
    <span id="tts-text">Đọc bài viết</span>
  </button>

  <!-- Nút Toggle Tự Động Đọc Lại -->
  <label class="flex items-center gap-2 text-sm cursor-pointer font-medium text-zinc-600 dark:text-zinc-400">
    <input type="checkbox" id="tts-replay" class="w-4 h-4 rounded accent-indigo-600 dynamic-checkbox" />
    <span>Tự động đọc lại</span>
  </label>
</div>

<script>
  let isSpeaking = false;
  let utterance: SpeechSynthesisUtterance | null = null;

  const button = document.getElementById('tts-button');
  const ttsText = document.getElementById('tts-text');
  const ttsIcon = document.getElementById('tts-icon');
  const replayCheckbox = document.getElementById('tts-replay') as HTMLInputElement;

  function getPostContent() {
    const contentElement = document.querySelector('article') || document.querySelector('.content');
    return contentElement ? contentElement.innerText : '';
  }

  function startSpeaking() {
    if (!('speechSynthesis' in window)) return;

    const text = getPostContent();
    if (!text) return;

    utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = document.documentElement.lang || 'vi-VN';
    utterance.rate = 1.1;

    // Chọn giọng đọc tối ưu nếu có
    const voices = window.speechSynthesis.getVoices();
    const optimalVoice = voices.find(v => v.lang.includes('vi') && (v.name.includes('Natural') || v.name.includes('Google')));
    if (optimalVoice) utterance.voice = optimalVoice;

    utterance.onstart = () => {
      isSpeaking = true;
      if (ttsText) ttsText.innerText = 'Dừng đọc';
      if (ttsIcon) ttsIcon.innerText = '⏹️';
    };

    utterance.onend = () => {
      isSpeaking = false;
      
      // KIỂM TRA NẾU USER BẬT "TỰ ĐỘNG ĐỌC LẠI"
      if (replayCheckbox && replayCheckbox.checked) {
        // Delay 1 giây trước khi đọc lại cho tự nhiên
        setTimeout(() => {
          startSpeaking();
        }, 1000);
      } else {
        if (ttsText) ttsText.innerText = 'Đọc bài viết';
        if (ttsIcon) ttsIcon.innerText = '🔊';
      }
    };

    utterance.onerror = () => {
      isSpeaking = false;
      if (ttsText) ttsText.innerText = 'Đọc bài viết';
      if (ttsIcon) ttsIcon.innerText = '🔊';
    };

    window.speechSynthesis.speak(utterance);
  }

  if (button) {
    button.addEventListener('click', () => {
      if (!('speechSynthesis' in window)) {
        alert('Trình duyệt của bạn không hỗ trợ tính năng đọc văn bản.');
        return;
      }

      if (isSpeaking) {
        // Khi chủ động bấm Dừng, ta tắt luôn trạng thái tự động đọc lại để tránh lặp vô hạn
        if (replayCheckbox) replayCheckbox.checked = false;
        window.speechSynthesis.cancel();
        isSpeaking = false;
        if (ttsText) ttsText.innerText = 'Đọc bài viết';
        if (ttsIcon) ttsIcon.innerText = '🔊';
        return;
      }

      startSpeaking();
    });
  }

  // Giải phóng bộ nhớ và tránh lỗi voice chạy ngầm khi chuyển trang trong Astro
  document.addEventListener('astro:before-preparation', () => {
    if (window.speechSynthesis) {
      window.speechSynthesis.cancel();
    }
  });

  // Hỗ trợ tải danh sách giọng đọc (một số trình duyệt tải giọng đọc bất đồng bộ)
  if ('speechSynthesis' in window) {
    window.speechSynthesis.onvoiceschanged = () => {};
  }
</script>
